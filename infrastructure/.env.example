# PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_HOST=
POSTGRES_PORT=5432

# Строки подключения для каждого сервиса
AUTH_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/taskflow_auth
TASKS_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/taskflow_tasks
NOTIFICATIONS_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/taskflow_notifications

# Тестовые базы
AUTH_DATABASE_URL_TEST=postgresql://USER:PASSWORD@HOST:5432/taskflow_auth_test
TASKS_DATABASE_URL_TEST=postgresql://USER:PASSWORD@HOST:5432/taskflow_tasks_test

# Redis
REDIS_PASSWORD=
REDIS_URL=redis://:PASSWORD@HOST:6379

# JWT
# Генерация: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d